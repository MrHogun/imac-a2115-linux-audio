[Unit]
Description=iMac A2115 audio DSP setup
After=pipewire.service wireplumber.service pipewire-pulse.service
Wants=pipewire.service wireplumber.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStartPre=/bin/sleep 4
ExecStart=/bin/bash -c '\
  pactl set-card-profile alsa_card.pci-0000_00_1f.3 output:analog-surround-40+input:analog-stereo && \
  sleep 1 && \
  pactl set-default-sink imac_dsp_in'

[Install]
WantedBy=default.target
